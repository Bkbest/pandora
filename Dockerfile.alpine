FROM python:3.11.15-alpine3.23

# Install system dependencies
RUN apk add --no-cache curl nodejs npm bash git msmtp

# Create workspace and venv directory
RUN mkdir -p /workspace/.packages
RUN python -m venv /workspace/.venv

# Set Python to use UTF-8 and venv as primary
ENV PYTHONIOENCODING=utf-8 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PATH=/workspace/.venv/bin:$PATH

# Create a workspace directory
WORKDIR /workspace

# Default command
CMD ["python"]
